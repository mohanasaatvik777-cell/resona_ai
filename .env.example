# Murf Falcon TTS API Key
MURF_API_KEY=your_murf_api_key_here

# --- LLM Provider (pick ONE, or leave both blank for offline fallback) ---

# Option 1: Groq (FREE — get key at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Option 2: OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Assistant persona: tutor | customer_support | productivity | language_coach
ASSISTANT_MODE=tutor

# Murf voice ID (see https://murf.ai/api/docs for available voices)
MURF_VOICE_ID=en-US-natalie
