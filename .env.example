# Murf Falcon TTS API Key (get at https://murf.ai/api)
MURF_API_KEY=your_murf_api_key_here

# Google Gemini API Keys — add multiple for automatic rotation on rate limit
# Get free keys at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_primary_gemini_key_here
GEMINI_API_KEY_2=your_second_gemini_key_here
GEMINI_API_KEY_3=your_third_gemini_key_here

# Assistant persona: tutor | customer_support | productivity | language_coach
ASSISTANT_MODE=tutor

# Murf voice ID
MURF_VOICE_ID=en-US-natalie
